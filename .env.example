# BitMerchant — copy to `.env` for local tools that load dotenv, or export vars in your shell.
# The Go server reads these via `cmd/server/config.go` (see README “Environment variables”).
#
# For Docker Compose, use `.env.docker` (see docker-compose.yml) — DATABASE_URL host is `postgres`.

# -----------------------------------------------------------------------------
# Server (required in production for correct URLs, WebAuthn, and QR links)
# -----------------------------------------------------------------------------

# HTTP listen port (default: 8080)
PORT=8080

# Public origin of the app, including scheme — used for WebAuthn RP ID (hostname),
# customer menu/QR links, and cookie security hints. Default: http://localhost:8080
BASE_URL=http://localhost:8080

# Set to `true` so session cookies use the Secure flag (typical behind HTTPS).
# COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# PostgreSQL (optional)
# -----------------------------------------------------------------------------

# If set, core + auth data use Postgres and Goose migrations run on startup.
# If unset, the app uses in-memory repositories (data lost on restart).
DATABASE_URL=postgres://bitmerchant:bitmerchant@localhost:5432/bitmerchant?sslmode=disable

# -----------------------------------------------------------------------------
# S3 — menu item photos (optional)
# -----------------------------------------------------------------------------

# Preferred names (AWS-style). Legacy aliases still work — see cmd/server/config.go.
# If AWS_S3_BUCKET_NAME or AWS_DEFAULT_REGION is unset, photo uploads are disabled.
# AWS_S3_BUCKET_NAME=bitmerchant-photos
# AWS_DEFAULT_REGION=us-east-1
#
# Non-AWS S3 (MinIO, Cloudflare R2, etc.): set endpoint and usually path-style.
# AWS_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_USE_PATH_STYLE=true
# Optional: helps parse object keys from legacy menu rows (new uploads store keys only).
# S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# Presigned GET lifetime in seconds for private buckets (default 3600).
# S3_PRESIGN_GET_EXPIRES=3600

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Legacy aliases: S3_BUCKET_NAME, AWS_REGION, S3_ENDPOINT

# -----------------------------------------------------------------------------
# Docker Compose hints (not read by the Go binary)
# When using `docker compose`, the `postgres` service uses these; build DATABASE_URL to match.
# POSTGRES_USER=bitmerchant
# POSTGRES_PASSWORD=bitmerchant
# POSTGRES_DB=bitmerchant
# POSTGRES_PORT=5432
